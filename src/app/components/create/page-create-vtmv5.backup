        </nav>
        <main>
            <div class="container">
                <h1 class="heading content">
                    Vampire: the Masquerade
                </h1>
                <h2>
                    Character Builder
                </h2>
            </div>
            <div class="creator-wrapper">
                <aside class="creator-legend" id="creatorLegend">
                    <div class="legend-step active" data-step="1" onclick="navigateToStep(1)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#e3e3e3">
                            <path d="M234-276q51-39 114-61.5T480-360q69 0 132 22.5T726-276q35-41 54.5-93T800-480q0-133-93.5-226.5T480-800q-133 0-226.5 93.5T160-480q0 59 19.5 111t54.5 93Zm246-164q-59 0-99.5-40.5T340-580q0-59 40.5-99.5T480-720q59 0 99.5 40.5T620-580q0 59-40.5 99.5T480-440Z"/>
                        </svg>
                        <span>1</span>
                    </div>
                    <div class="legend-step" data-step="2" onclick="navigateToStep(2)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#e3e3e3">
                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                        </svg>
                        <span>2</span>
                    </div>
                    <div class="legend-step" data-step="3" onclick="navigateToStep(3)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#e3e3e3">
                            <path d="M480-120 200-272v-240L480-360l280-152v240L480-120Zm0-332L274-480l206-148 206 148-206 148Zm0 241 224-116v-168L480-360 256-455v168l224 116Zm0-241Zm0 241Zm0 0Z"/>
                        </svg>
                        <span>3</span>
                    </div>
                    <div class="legend-step" data-step="4" onclick="navigateToStep(4)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#e3e3e3">
                            <path d="M480-120q-150 0-255-105T120-480q0-150 105-255t255-105q14 0 27.5 1t26.5 3l-44 44q-11-2-22-3t-22-1q-109 0-184.5 75.5T220-480q0 109 75.5 184.5T480-220q109 0 184.5-75.5T740-480q0-11-1-22t-3-22l44-44q2 13 3 26.5t1 27.5q0 150-105 255T480-120Zm-56-216 56-57 56 57 56-56-57-56 57-56-56-56-56 56-56-56-57 56 57 56-57 56 56 56Zm370 246-56-56 56-56-56-56 56-56 56 56-56 56 56 56-56 56Z"/>
                        </svg>
                        <span>4</span>
                    </div>
                    <div class="legend-step" data-step="5" onclick="navigateToStep(5)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#e3e3e3">
                            <path d="M480-120q-150 0-255-105T120-480q0-150 105-255t255-105q150 0 255 105t105 255q0 150-105 255T480-120Zm0-80q109 0 184.5-75.5T740-480q0-109-75.5-184.5T480-740q-109 0-184.5 75.5T220-480q0 109 75.5 184.5T480-220Zm0-60q-75 0-127.5-52.5T300-480q0-75 52.5-127.5T480-660q75 0 127.5 52.5T660-480q0 75-52.5 127.5T480-300Z"/>
                        </svg>
                        <span>5</span>
                    </div>
                    <div class="legend-step" data-step="6" onclick="navigateToStep(6)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#e3e3e3">
                            <path d="M480-120q-150 0-255-105T120-480q0-150 105-255t255-105q150 0 255 105t105 255q0 150-105 255T480-120Zm0-80q109 0 184.5-75.5T740-480q0-109-75.5-184.5T480-740q-109 0-184.5 75.5T220-480q0 109 75.5 184.5T480-220Zm0-60q-75 0-127.5-52.5T300-480q0-75 52.5-127.5T480-660q75 0 127.5 52.5T660-480q0 75-52.5 127.5T480-300Z"/>
                        </svg>
                        <span>6</span>
                    </div>
                </aside>
                <div class="container create" id="createContainer" data-background-image="../../content/images/vtmv5_container_background.jpg">
                    <!-- Step 1: Character Name -->
                    <div class="creator-box active" id="step-1" data-step="1">
                        <div class="creator-box-header" onclick="toggleBox(1)">
                            <h4>Who is Your Kindred?</h4>
                            <svg class="collapse-icon" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3">
                                <path d="M480-360 280-560h400L480-360Z"/>
                            </svg>
                        </div>
                        <div class="creator-box-content">
                            <div class="character-inputs" id="character-inputs-container">
                                <label class="char-input">
                                    <b>Character Name</b>
                                    <input type="text" placeholder="What is your name?" data-testId="charNameInput" name="name" id="characterName" required>
                                    <span class="error" aria-live="polite" id="name-error"></span>
                                </label>
                                <label class="char-input">
                                    <b>Character Age</b>
                                    <select id="characterAge" name="characterAge" class="char-input" required>
                                        <option value="">Select Age</option>
                                        <option value="neonate">Childer (embraced within the last 15 years)</option>
                                        <option value="ancilla">Neonate (embraced 15 - 50 years ago)</option>
                                        <option value="elder">Ancilla (embraced 50 - 100 years ago)</option>
                                    </select>
                                </label>
                                <label class="char-input">
                                    <b>Sire Name</b>
                                    <input type="text" placeholder="What is their name?" data-testId="sireNameInput" name="name" id="sireName" required>
                                    <span class="error" aria-live="polite" id="name-error"></span>
                                </label>
                                <label class="char-input">
                                    <b>Sire Generation</b>
                                    <input placeholder="Generation from 2-12" data-testId="sireGenInput" type="text" inputmode="numeric" pattern="([2-9]|1[0-2])" id="generation" required>
                                    <span class="error" aria-live="polite" id="generation-error"></span>
                                </label>
                            </div>
                            <button type="button" class="step-submit-btn" onclick="submitStep(1)">Continue</button>
                        </div>
                    </div>

                    <!-- Step 2: Clan Picker -->
                    <div class="creator-box" id="step-2" data-step="2">
                        <div class="creator-box-header" onclick="toggleBox(2)">
                            <h4>Choose Your Clan</h4>
                            <svg class="collapse-icon" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3">
                                <path d="M480-360 280-560h400L480-360Z"/>
                            </svg>
                        </div>
                        <div class="creator-box-content">
                            <div class="clan-grid" id="clanGrid">
                                <div class="clan-option" data-clan="brujah">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Brujah</span>
                                </div>
                                <div class="clan-option" data-clan="gangrel">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Gangrel</span>
                                </div>
                                <div class="clan-option" data-clan="malkavian">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Malkavian</span>
                                </div>
                                <div class="clan-option" data-clan="nosferatu">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Nosferatu</span>
                                </div>
                                <div class="clan-option" data-clan="toreador">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Toreador</span>
                                </div>
                                <div class="clan-option" data-clan="tremere">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Tremere</span>
                                </div>
                                <div class="clan-option" data-clan="ventrue">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Ventrue</span>
                                </div>
                                <div class="clan-option" data-clan="banu-haqim">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Banu Haqim</span>
                                </div>
                                <div class="clan-option" data-clan="caitiff">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Caitiff</span>
                                </div>
                                <div class="clan-option" data-clan="hecata">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Hecata</span>
                                </div>
                                <div class="clan-option" data-clan="lasombra">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Lasombra</span>
                                </div>
                                <div class="clan-option" data-clan="ministry">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Ministry</span>
                                </div>
                                <div class="clan-option" data-clan="ravnos">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Ravnos</span>
                                </div>
                                <div class="clan-option" data-clan="tzimisce">
                                    <div class="clan-image">
                                        <svg xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#e3e3e3">
                                            <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/>
                                        </svg>
                                    </div>
                                    <span class="clan-name">Tzimisce</span>
                                </div>
                            </div>
                            <div class="clan-details" id="clanDetails" style="display: none;">
                                <h5 id="selectedClanName"></h5>
                                <p id="clanInfo" rows="6"></p>
                            </div>
                            <button type="button" class="step-submit-btn" onclick="submitStep(2)" id="step2Submit" style="display: none;">Continue</button>
                        </div>
                    </div>

                    <!-- Step 3: Attributes -->
                    <div class="creator-box" id="step-3" data-step="3">
                        <div class="creator-box-header" onclick="toggleBox(3)">
                            <h4>Attributes, Skills & Specialties</h4>
                            <svg class="collapse-icon" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3">
                                <path d="M480-360 280-560h400L480-360Z"/>
                            </svg>
                        </div>
                        <div class="creator-box-content">
                            <!-- Attributes Section -->
                            <div class="attributes-section">
                                <h5>Attributes</h5>
                                <div class="attributes-container">
                                    <div class="attribute-category">
