        <script type="module" src="../../js/pages/create/vtmv5/trackerModule.js" defer></script>
        <script type="module" src="../../js/pages/create/vtmv5/dataValidation.js" defer></script>
        <script type="module" src="../../js/pages/create/vtmv5/helpers.js" defer></script>
    </head>
    <body>
        <nav id="sidebar">
            <ul>
                <li>
                    <span class="logo">Character Vault</span>
